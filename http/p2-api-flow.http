### 31. 분쟁 COMPLETE 종료
POST {{baseUrl}}/api/refund/{{p2CompleteDisputeRefundId}}/resolve
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "resolution": "COMPLETE"
}

> {%
client.test("분쟁 COMPLETE 종료는 거래 완료 상태를 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "CLOSED", "CLOSED를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "COMPLETED", "COMPLETED 주문을 기대했습니다.");
  client.assert(response.body.data.productStatus === "SOLD_OUT", "SOLD_OUT을 기대했습니다.");
});
%}

