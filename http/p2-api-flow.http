### P2 REST API 흐름
### 로컬 앱이 http://localhost:8080 에 떠 있는 상태에서 위에서 아래 순서로 실행한다.
### 이 파일은 실행 중인 앱의 MySQL/Redis 연결이 필요하다.
### 수동 실행 전 .env 설정, docker compose up -d mysql redis, ./gradlew bootRun 이 필요하다.
### 실행 전 상품 등록에 사용할 카테고리가 1개 이상 있어야 한다.
### 이 파일은 JetBrains HTTP Client 응답 핸들러를 사용한다.
### 시나리오 설명은 docs/P2_TEST_SCENARIOS.md에 정리되어 있다.

@baseUrl = http://localhost:8080
@runId = {{$timestamp}}
@password = Password123!
@approvePaymentKey = p2-approve-payment-{{runId}}
@refundPaymentKey = p2-refund-payment-{{runId}}
@completePaymentKey = p2-complete-payment-{{runId}}
@reviewPaymentKey = p2-review-payment-{{runId}}

### 01. 판매자 회원가입
# @name signupP2Seller
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p2-seller-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P2판매자"
}

> {%
client.test("판매자 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p2SellerId", response.body.data.userId);
%}

### 02. 구매자 회원가입
# @name signupP2Buyer
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p2-buyer-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P2구매자"
}

> {%
client.test("구매자 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p2BuyerId", response.body.data.userId);
%}

### 03. 타인 회원가입
# @name signupP2Other
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p2-other-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P2타인"
}

> {%
client.test("타인 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p2OtherId", response.body.data.userId);
%}

### 04. 판매자 로그인
# @name loginP2Seller
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "p2-seller-{{runId}}@example.com",
  "password": "{{password}}"
}

> {%
client.test("판매자 로그인은 토큰을 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(!!response.body.data.accessToken, "access token이 없습니다.");
});
client.global.set("p2SellerAccessToken", response.body.data.accessToken);
client.global.set("p2SellerId", response.body.data.user.userId);
%}

