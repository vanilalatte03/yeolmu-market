### 07. 카테고리 목록 조회
# @name getP2Categories
GET {{baseUrl}}/api/categories

> {%
client.test("카테고리 목록은 1개 이상이어야 한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.categories.length > 0, "상품 등록에 사용할 카테고리가 없습니다.");
});
client.global.set("p2CategoryId", response.body.data.categories[0].categoryId);
%}

### 08. 환불 승인용 상품 등록
# @name createP2ApproveProduct
POST {{baseUrl}}/api/products
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "title": "P2 환불 승인 상품 {{runId}}",
  "description": "P2 환불 승인 흐름 검증용 상품입니다.",
  "price": 430000,
  "categoryId": {{p2CategoryId}}
}

> {%
client.test("환불 승인용 상품 등록은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p2ApproveProductId", response.body.data.productId);
%}

### 09. 환불 승인용 주문 생성
# @name createP2ApproveOrder
POST {{baseUrl}}/api/products/{{p2ApproveProductId}}/orders
Authorization: Bearer {{p2BuyerAccessToken}}

> {%
client.test("환불 승인용 주문은 CREATED로 생성된다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "CREATED", "CREATED를 기대했습니다.");
});
client.global.set("p2ApproveOrderId", response.body.data.orderId);
%}

### 10. 환불 승인용 결제 성공
POST {{baseUrl}}/api/orders/{{p2ApproveOrderId}}/payment
Authorization: Bearer {{p2BuyerAccessToken}}
Idempotency-Key: {{approvePaymentKey}}
Content-Type: application/json

{
  "method": "MOCK_CARD",
  "result": "PAID"
}

> {%
client.test("환불 승인용 결제는 PAID를 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "PAID", "PAID를 기대했습니다.");
});
client.global.set("p2ApprovePaymentId", response.body.data.paymentId);
%}

### 11. 환불 승인용 배송 증빙 등록
PATCH {{baseUrl}}/api/orders/{{p2ApproveOrderId}}/shipping
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "trackingNumber": "P2-APPROVE-{{runId}}"
}

> {%
client.test("환불 승인용 주문은 SHIPPING이 된다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "SHIPPING", "SHIPPING을 기대했습니다.");
});
%}

### 12. 구매자 환불 요청
# @name requestP2ApproveRefund
POST {{baseUrl}}/api/orders/{{p2ApproveOrderId}}/refund
Authorization: Bearer {{p2BuyerAccessToken}}
Content-Type: application/json

{
  "reason": "상품 상태가 설명과 다릅니다."
}

> {%
client.test("환불 요청은 REQUESTED를 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "REQUESTED", "REQUESTED를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "REFUND_REQUESTED", "REFUND_REQUESTED를 기대했습니다.");
});
client.global.set("p2ApproveRefundId", response.body.data.refundRequestId);
%}

### 13. 판매자가 아닌 사용자의 환불 승인 실패
POST {{baseUrl}}/api/refund/{{p2ApproveRefundId}}/approve
Authorization: Bearer {{p2BuyerAccessToken}}

> {%
client.test("판매자가 아닌 사용자는 환불 승인할 수 없다", function () {
  client.assert(response.status === 403, "403을 기대했습니다.");
  client.assert(response.body.code === "REFUND_REQUEST_ACCESS_DENIED", "REFUND_REQUEST_ACCESS_DENIED를 기대했습니다.");
});
%}

### 14. 판매자 환불 승인
POST {{baseUrl}}/api/refund/{{p2ApproveRefundId}}/approve
Authorization: Bearer {{p2SellerAccessToken}}

> {%
client.test("판매자는 환불 요청을 승인할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "APPROVED", "APPROVED를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "REFUNDED", "REFUNDED를 기대했습니다.");
  client.assert(response.body.data.productStatus === "ON_SALE", "ON_SALE을 기대했습니다.");
});
%}

### 15. 환불 승인 후 결제 상태 조회
GET {{baseUrl}}/api/payments/{{p2ApprovePaymentId}}/status
Authorization: Bearer {{p2BuyerAccessToken}}

> {%
client.test("환불 승인 후 결제는 REFUNDED다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "REFUNDED", "REFUNDED를 기대했습니다.");
});
%}

