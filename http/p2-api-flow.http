### 21. 판매자 환불 요청 거절
POST {{baseUrl}}/api/refund/{{p2RefundDisputeRefundId}}/reject
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "reason": "판매자는 정상 상품으로 판단합니다."
}

> {%
client.test("환불 거절은 DISPUTED를 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "DISPUTED", "DISPUTED를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "DISPUTED", "DISPUTED 주문을 기대했습니다.");
});
%}

### 22. 판매자가 아닌 사용자의 분쟁 종료 실패
POST {{baseUrl}}/api/refund/{{p2RefundDisputeRefundId}}/resolve
Authorization: Bearer {{p2BuyerAccessToken}}
Content-Type: application/json

{
  "resolution": "REFUND"
}

> {%
client.test("판매자가 아닌 사용자는 분쟁 종료할 수 없다", function () {
  client.assert(response.status === 403, "403을 기대했습니다.");
  client.assert(response.body.code === "REFUND_REQUEST_ACCESS_DENIED", "REFUND_REQUEST_ACCESS_DENIED를 기대했습니다.");
});
%}

### 23. 잘못된 resolution 분쟁 종료 실패
POST {{baseUrl}}/api/refund/{{p2RefundDisputeRefundId}}/resolve
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "resolution": "INVALID"
}

> {%
client.test("잘못된 resolution은 validation 실패를 반환한다", function () {
  client.assert(response.status === 400, "400을 기대했습니다.");
  client.assert(response.body.code === "VALIDATION_FAILED", "VALIDATION_FAILED를 기대했습니다.");
});
%}

### 24. 분쟁 REFUND 종료
POST {{baseUrl}}/api/refund/{{p2RefundDisputeRefundId}}/resolve
Authorization: Bearer {{p2SellerAccessToken}}
Content-Type: application/json

{
  "resolution": "REFUND",
  "reason": "구매자 환불로 종료합니다."
}

> {%
client.test("분쟁 REFUND 종료는 주문과 결제를 환불한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "CLOSED", "CLOSED를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "REFUNDED", "REFUNDED 주문을 기대했습니다.");
  client.assert(response.body.data.productStatus === "ON_SALE", "ON_SALE을 기대했습니다.");
});
%}

