### 04. 판매자 로그인
# @name loginSeller
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "seller-{{runId}}@example.com",
  "password": "{{password}}"
}

> {%
client.test("판매자 로그인은 토큰을 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(!!response.body.data.accessToken, "access token이 없습니다.");
  client.assert(!!response.body.data.refreshToken, "refresh token이 없습니다.");
});
client.global.set("sellerAccessToken", response.body.data.accessToken);
client.global.set("sellerRefreshToken", response.body.data.refreshToken);
client.global.set("sellerId", response.body.data.user.userId);
%}

