### 31. 구매자1 주문 취소
POST {{baseUrl}}/api/orders/{{orderId}}/cancel
Authorization: Bearer {{buyer1AccessToken}}

> {%
client.test("구매자는 본인 주문을 취소할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "CANCELED", "CANCELED를 기대했습니다.");
  client.assert(response.body.data.productStatus === "ON_SALE", "상품 ON_SALE을 기대했습니다.");
});
%}

