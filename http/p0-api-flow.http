### 10. 판매자 상품 등록
# @name createProduct
POST {{baseUrl}}/api/products
Authorization: Bearer {{sellerAccessToken}}
Content-Type: application/json

{
  "title": "아이패드 미니 6세대 {{runId}}",
  "description": "생활기스 조금 있는 중고 상품입니다.",
  "price": 430000,
  "categoryId": {{categoryId}}
}

> {%
client.test("상품 등록은 판매 중 상품을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "ON_SALE", "ON_SALE을 기대했습니다.");
});
client.global.set("productId", response.body.data.productId);
%}

