  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "ON_SALE", "ON_SALE을 기대했습니다.");
});
%}

### 33. 구매자1 토큰 재발급
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{buyer1RefreshToken}}"
}

> {%
client.test("토큰 재발급은 토큰을 회전한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(!!response.body.data.accessToken, "재발급된 access token이 없습니다.");
  client.assert(!!response.body.data.refreshToken, "재발급된 refresh token이 없습니다.");
});
client.global.set("buyer1OldAccessToken", client.global.get("buyer1AccessToken"));
client.global.set("buyer1OldRefreshToken", client.global.get("buyer1RefreshToken"));
client.global.set("buyer1AccessToken", response.body.data.accessToken);
client.global.set("buyer1RefreshToken", response.body.data.refreshToken);
%}

### 34. 이전 refresh token은 폐기됨
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{buyer1OldRefreshToken}}"
}

> {%
client.test("회전 후 이전 refresh token은 거부된다", function () {
  client.assert(response.status === 401, "401을 기대했습니다.");
});
%}

