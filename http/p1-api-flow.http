### 07. 카테고리 목록 조회 - 첫 카테고리를 상품 등록에 사용
# @name getCategories
GET {{baseUrl}}/api/categories

> {%
client.test("카테고리 목록은 1개 이상이어야 한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.categories.length > 0, "상품 등록에 사용할 카테고리가 없습니다.");
});
client.global.set("p1CategoryId", response.body.data.categories[0].categoryId);
%}

### 08. 판매자 상품 등록
# @name createP1Product
POST {{baseUrl}}/api/products
Authorization: Bearer {{p1SellerAccessToken}}
Content-Type: application/json

{
  "title": "P1 거래 상품 {{runId}}",
  "description": "P1 핵심 거래 흐름 검증용 상품입니다.",
  "price": 430000,
  "categoryId": {{p1CategoryId}}
}

> {%
client.test("상품 등록은 판매 중 상품을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "ON_SALE", "ON_SALE을 기대했습니다.");
});
client.global.set("p1ProductId", response.body.data.productId);
%}

### 09. 카테고리별 상품 목록 조회
GET {{baseUrl}}/api/categories/{{p1CategoryId}}/products?page=0&size=10&sort=latest

> {%
client.test("카테고리별 상품 목록을 조회할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
});
%}

### 10. 구매자 상품 찜 등록
POST {{baseUrl}}/api/products/{{p1ProductId}}/wishes
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("구매자는 상품을 찜할 수 있다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.wished === true, "wished=true를 기대했습니다.");
  client.assert(response.body.data.wishCount === 1, "wishCount=1을 기대했습니다.");
});
%}

### 11. 구매자 내 찜 목록 조회
GET {{baseUrl}}/api/users/me/wishes?page=0&size=10
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("내 찜 목록에 상품이 포함된다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.totalElements >= 1, "찜 목록에 상품이 있어야 합니다.");
});
%}

### 12. 구매자 상품 찜 취소
DELETE {{baseUrl}}/api/products/{{p1ProductId}}/wishes
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("구매자는 상품 찜을 취소할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.wished === false, "wished=false를 기대했습니다.");
  client.assert(response.body.data.wishCount === 0, "wishCount=0을 기대했습니다.");
});
%}

### 13. 찜 취소 후 내 찜 목록 조회
GET {{baseUrl}}/api/users/me/wishes?page=0&size=10
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("찜 취소 후 내 찜 목록 조회는 200을 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
});
%}

### 14. 구매자 주문 생성
# @name createP1Order
POST {{baseUrl}}/api/products/{{p1ProductId}}/orders
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("구매자는 상품을 주문할 수 있다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "CREATED", "CREATED 주문을 기대했습니다.");
});
client.global.set("p1OrderId", response.body.data.orderId);
%}

### 15. 주문 후 상품 상세 - RESERVED
GET {{baseUrl}}/api/products/{{p1ProductId}}

> {%
client.test("주문 생성 후 상품은 RESERVED가 된다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "RESERVED", "RESERVED를 기대했습니다.");
});
%}

### 16. 결제 전 배송 증빙 등록 실패
PATCH {{baseUrl}}/api/orders/{{p1OrderId}}/shipping
Authorization: Bearer {{p1SellerAccessToken}}
Content-Type: application/json

{
  "trackingNumber": "PREPAY-{{runId}}"
}

> {%
client.test("CREATED 주문은 배송 증빙 등록을 거부한다", function () {
  client.assert(response.status === 409, "409를 기대했습니다.");
  client.assert(response.body.code === "INVALID_ORDER_STATUS", "INVALID_ORDER_STATUS를 기대했습니다.");
});
%}

### 17. CREATED 주문 구매확정 실패
POST {{baseUrl}}/api/orders/{{p1OrderId}}/confirm
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("CREATED 주문은 구매확정을 거부한다", function () {
  client.assert(response.status === 409, "409를 기대했습니다.");
  client.assert(response.body.code === "INVALID_ORDER_STATUS", "INVALID_ORDER_STATUS를 기대했습니다.");
});
%}

### 18. 구매자 모의 결제 성공
# @name payP1Order
POST {{baseUrl}}/api/orders/{{p1OrderId}}/payment
Authorization: Bearer {{p1BuyerAccessToken}}
Idempotency-Key: {{paymentKey}}
Content-Type: application/json

{
  "method": "MOCK_CARD",
  "result": "PAID"
}

> {%
client.test("결제 성공은 PAID 상태를 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
  client.assert(response.body.data.status === "PAID", "결제 PAID를 기대했습니다.");
  client.assert(response.body.data.orderStatus === "PAID", "주문 PAID를 기대했습니다.");
  client.assert(response.body.data.productStatus === "RESERVED", "상품 RESERVED를 기대했습니다.");
});
client.global.set("p1PaymentId", response.body.data.paymentId);
%}

### 19. PAID 주문 구매확정 실패
POST {{baseUrl}}/api/orders/{{p1OrderId}}/confirm
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("PAID 주문은 구매확정을 거부한다", function () {
  client.assert(response.status === 409, "409를 기대했습니다.");
  client.assert(response.body.code === "INVALID_ORDER_STATUS", "INVALID_ORDER_STATUS를 기대했습니다.");
});
%}

### 20. 같은 Idempotency-Key로 결제 재요청
POST {{baseUrl}}/api/orders/{{p1OrderId}}/payment
Authorization: Bearer {{p1BuyerAccessToken}}
Idempotency-Key: {{paymentKey}}
Content-Type: application/json

{
  "method": "MOCK_CARD",
  "result": "PAID"
}

> {%
client.test("같은 멱등키 결제 재요청은 기존 결제를 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.paymentId == client.global.get("p1PaymentId"), "기존 paymentId를 기대했습니다.");
  client.assert(response.body.data.status === "PAID", "PAID를 기대했습니다.");
});
%}

### 21. 다른 Idempotency-Key로 결제 재요청 실패
POST {{baseUrl}}/api/orders/{{p1OrderId}}/payment
Authorization: Bearer {{p1BuyerAccessToken}}
Idempotency-Key: {{duplicatePaymentKey}}
Content-Type: application/json

{
  "method": "MOCK_CARD",
  "result": "PAID"
}

> {%
client.test("다른 멱등키 결제 재요청은 거부된다", function () {
  client.assert(response.status === 409, "409를 기대했습니다.");
  client.assert(response.body.code === "PAYMENT_ALREADY_EXISTS", "PAYMENT_ALREADY_EXISTS를 기대했습니다.");
});
%}

### 22. 타인의 배송 증빙 등록 실패
PATCH {{baseUrl}}/api/orders/{{p1OrderId}}/shipping
Authorization: Bearer {{p1OtherAccessToken}}
Content-Type: application/json

{
  "trackingNumber": "OTHER-{{runId}}"
}

> {%
client.test("주문 판매자가 아닌 사용자는 배송 증빙을 등록할 수 없다", function () {
  client.assert(response.status === 403, "403을 기대했습니다.");
  client.assert(response.body.code === "ORDER_ACCESS_DENIED", "ORDER_ACCESS_DENIED를 기대했습니다.");
});
%}

### 23. 판매자 배송 증빙 등록
PATCH {{baseUrl}}/api/orders/{{p1OrderId}}/shipping
Authorization: Bearer {{p1SellerAccessToken}}
Content-Type: application/json

{
  "trackingNumber": " {{trackingNumber}} "
}

> {%
client.test("판매자는 PAID 주문에 배송 증빙을 등록할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "SHIPPING", "SHIPPING을 기대했습니다.");
  client.assert(response.body.data.trackingNumber.startsWith("P1-TRACK-"), "trim된 송장 번호를 기대했습니다.");
});
%}

### 24. 배송 증빙 등록 후 단순 주문 취소 실패
POST {{baseUrl}}/api/orders/{{p1OrderId}}/cancel
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("SHIPPING 주문은 단순 취소를 거부한다", function () {
  client.assert(response.status === 409, "409를 기대했습니다.");
  client.assert(response.body.code === "INVALID_ORDER_STATUS", "INVALID_ORDER_STATUS를 기대했습니다.");
});
%}

### 25. 타인의 구매확정 실패
POST {{baseUrl}}/api/orders/{{p1OrderId}}/confirm
Authorization: Bearer {{p1OtherAccessToken}}

> {%
client.test("주문 구매자가 아닌 사용자는 구매확정할 수 없다", function () {
  client.assert(response.status === 403, "403을 기대했습니다.");
  client.assert(response.body.code === "ORDER_ACCESS_DENIED", "ORDER_ACCESS_DENIED를 기대했습니다.");
});
%}

### 26. 구매자 구매확정
POST {{baseUrl}}/api/orders/{{p1OrderId}}/confirm
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("구매자는 SHIPPING 주문을 구매확정할 수 있다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "COMPLETED", "COMPLETED를 기대했습니다.");
  client.assert(response.body.data.productStatus === "SOLD_OUT", "SOLD_OUT을 기대했습니다.");
});
%}

