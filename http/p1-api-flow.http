  client.assert(!!response.body.data.accessToken, "access token이 없습니다.");
});
client.global.set("p1BuyerAccessToken", response.body.data.accessToken);
client.global.set("p1BuyerRefreshToken", response.body.data.refreshToken);
client.global.set("p1BuyerId", response.body.data.user.userId);
