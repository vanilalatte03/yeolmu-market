### P1 REST API 흐름
### 로컬 앱이 http://localhost:8080 에 떠 있는 상태에서 위에서 아래 순서로 실행한다.
### 이 파일은 실행 중인 앱의 MySQL/Redis 연결이 필요하다.
### 수동 실행 전 .env 설정, docker compose up -d mysql redis, ./gradlew bootRun 이 필요하다.
### 실행 전 상품 등록에 사용할 카테고리가 1개 이상 있어야 한다.
### 빈 로컬 DB라면 관리자 카테고리 API 또는 SQL seed로 카테고리를 먼저 생성한다.
### 이 파일은 JetBrains HTTP Client 응답 핸들러를 사용한다.
### 시나리오 설명은 docs/P1_TEST_SCENARIOS.md에 정리되어 있다.

@baseUrl = http://localhost:8080
@runId = {{$timestamp}}
@password = Password123!
@trackingNumber = P1-TRACK-{{runId}}
@paymentKey = p1-payment-{{runId}}
@duplicatePaymentKey = p1-payment-duplicate-{{runId}}

### 01. 판매자 회원가입
# @name signupSeller
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p1-seller-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P1판매자"
}

> {%
client.test("판매자 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p1SellerId", response.body.data.userId);
%}

### 02. 구매자 회원가입
# @name signupBuyer
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p1-buyer-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P1구매자"
}

> {%
client.test("구매자 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p1BuyerId", response.body.data.userId);
%}

### 03. 타인 회원가입
# @name signupOther
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "p1-other-{{runId}}@example.com",
  "password": "{{password}}",
  "nickname": "P1타인"
}

> {%
client.test("타인 회원가입은 201을 반환한다", function () {
  client.assert(response.status === 201, "201을 기대했습니다.");
});
client.global.set("p1OtherId", response.body.data.userId);
%}

### 04. 판매자 로그인
# @name loginSeller
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "p1-seller-{{runId}}@example.com",
  "password": "{{password}}"
}

> {%
client.test("판매자 로그인은 토큰을 반환한다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(!!response.body.data.accessToken, "access token이 없습니다.");
});
client.global.set("p1SellerAccessToken", response.body.data.accessToken);
client.global.set("p1SellerRefreshToken", response.body.data.refreshToken);
client.global.set("p1SellerId", response.body.data.user.userId);
%}

