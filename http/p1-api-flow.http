client.test("구매확정 후 상품은 SOLD_OUT이 된다", function () {
  client.assert(response.status === 200, "200을 기대했습니다.");
  client.assert(response.body.data.status === "SOLD_OUT", "SOLD_OUT을 기대했습니다.");
});
%}

### 29. 구매확정 후 결제 상태 조회
GET {{baseUrl}}/api/payments/{{p1PaymentId}}/status
Authorization: Bearer {{p1BuyerAccessToken}}

> {%
client.test("거래 완료 후 결제는 PAID 상태를 유지한다", function () {
