POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "p1-buyer-{{runId}}@example.com",
  "password": "{{password}}"
}

> {%
client.test("구매자 로그인은 토큰을 반환한다", function () {
