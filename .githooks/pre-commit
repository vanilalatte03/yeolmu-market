#!/bin/sh
# Spotless 포맷 검사 (커밋 시 1회). 위반 시 커밋 차단.
# 클론 후 1회 활성화: git config core.hooksPath .githooks
echo "[pre-commit] spotlessCheck..."

if [ -x ./gradlew ]; then
  ./gradlew spotlessCheck -q
else
  ./gradlew.bat spotlessCheck -q
fi

if [ $? -ne 0 ]; then
  echo "[pre-commit] 포맷 위반. './gradlew spotlessApply' 실행 후 다시 add/commit 하세요."
  exit 1
fi
